from app import create_app
import os

# Get environment from FLASK_ENV variable, default to development
config_name = os.environ.get('FLASK_ENV', 'development')
app = create_app(config_name)

if __name__ == '__main__':
    print(f"ŪļÄ Starting server in {config_name} mode...")
    # Use Flask's built-in server (simpler and more reliable)
    app.run(debug=(config_name=='development'), host='0.0.0.0', port=5000)
