        accounts = Account.query.filter_by(
            church_id=church_id
        ).order_by(Account.account_type, Account.account_code).all()
        
        account_list = []
        for acc in accounts:
            account_list.append({
                'id': acc.id,
                'code': acc.account_code,
                'name': acc.name,
                'display_name': acc.display_name,
                'type': acc.account_type,
                'category': acc.category,
                'sub_category': acc.sub_category,
                'balance': float(acc.current_balance),
                'is_active': acc.is_active,
                'normal_balance': acc.normal_balance
            })
        
        return jsonify({
            'accounts': account_list,
            'total': len(account_list)
        }), 200
        
    except Exception as e:
        logger.error(f"Error getting accounts: {str(e)}")
        return jsonify({'error': 'Failed to get accounts'}), 500
    

@accounting_bp.route('/accounts', methods=['POST', 'OPTIONS'])
@token_required
def create_account():
    """Create a new account"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        current_user = get_current_user()
        data = request.get_json()
        
        print(f"\n{'='*60}")
        print(f"📥 CREATE ACCOUNT")
        print(f"{'='*60}")
        print(f"Request data: {json.dumps(data, indent=2)}")
        
        # Validate required fields
        required_fields = ['code', 'name', 'type']
        for field in required_fields:
            if not data.get(field):
                return jsonify({'error': f'{field} is required'}), 400
        
        # Check if account code already exists
        existing = Account.query.filter_by(
            church_id=church_id,
            account_code=data['code']
        ).first()
        
        if existing:
            return jsonify({'error': 'Account code already exists'}), 400
        
        # Validate account type
        account_type = data['type'].upper()
        valid_types = ['ASSET', 'LIABILITY', 'EQUITY', 'REVENUE', 'EXPENSE']
        if account_type not in valid_types:
            return jsonify({'error': f'Account type must be one of: {", ".join(valid_types)}'}), 400
        
        from decimal import Decimal
        opening_balance = Decimal(str(data.get('openingBalance', 0)))
        
        # Create account with CORRECT field names from your model
        account = Account(
            church_id=church_id,
            account_code=data['code'],
            name=data['name'],
            display_name=data.get('displayName', data['name']),  # This field exists
            account_type=account_type,
            category=data.get('category'),
            sub_category=data.get('subCategory'),  # This field exists
            parent_account_id=data.get('parentAccountId'),  # This field exists
            level=data.get('level', 1),  # This field exists
            opening_balance=opening_balance,
            current_balance=opening_balance,
            normal_balance=data.get('normalBalance', 'debit'),
            is_contra=data.get('isContra', False),  # This field exists
            description=data.get('description'),
            is_active=data.get('isActive', True),
            # Note: created_at and updated_at are auto-set by default values
        )
        
        db.session.add(account)
        db.session.commit()
        
        # Log audit if you have an AuditLog model (optional)
        # audit_log = AuditLog(
        #     user_id=current_user.id if current_user else None,
        #     action='CREATE_ACCOUNT',
        #     resource='account',
        #     resource_id=account.id,
        #     data={'account_code': account.account_code},
        #     ip_address=request.remote_addr,
        #     user_agent=request.user_agent.string if request.user_agent else None
        # )
        # db.session.add(audit_log)
        # db.session.commit()
        
        print(f"✅ Account created successfully with ID: {account.id}")
        
        return jsonify({
            'message': 'Account created successfully',
            'id': account.id,
            'account': {
                'id': account.id,
                'code': account.account_code,
                'name': account.name,
                'display_name': account.display_name,
                'type': account.account_type,
                'category': account.category,
                'sub_category': account.sub_category,
                'balance': float(account.current_balance),
                'is_active': account.is_active
            }
        }), 201
        
    except Exception as e:
        db.session.rollback()
        print(f"❌ Error creating account: {str(e)}")
        print(traceback.format_exc())
        return jsonify({'error': str(e)}), 500
    
@accounting_bp.route('/accounts/<int:account_id>', methods=['GET', 'OPTIONS'])
@token_required
def get_account(account_id):
    """Get a specific account"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        
        account = Account.query.filter_by(
            id=account_id,
            church_id=church_id
        ).first()
        
