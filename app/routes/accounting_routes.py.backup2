@accounting_bp.route('/alerts', methods=['GET', 'OPTIONS'])
@token_required
def get_alerts():
    """Get accounting alerts"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        alerts = []
        alert_id = 1
        
        from app.models import JournalEntry
        
        # Check for unreconciled journal entries
        pending_journals = JournalEntry.query.filter_by(
            church_id=church_id,
            status='DRAFT'
        ).count()
        
        if pending_journals > 0:
            alerts.append({
                'id': alert_id,
                'type': 'warning',
                'message': f'{pending_journals} journal entries in draft state',
                'severity': 'medium'
            })
            alert_id += 1
        
        # Check for unbalanced journal entries (shouldn't happen but just in case)
        # This is a complex check - simplified for now
        
        # Check for negative cash/bank accounts
        cash_accounts = Account.get_cash_accounts(church_id) + Account.get_bank_accounts(church_id)
        negative_cash = []
        for acc in cash_accounts:
            if acc.current_balance < 0:
                negative_cash.append(acc.name)
        
        if negative_cash:
            alerts.append({
                'id': alert_id,
                'type': 'error',
                'message': f'Negative balances in: {", ".join(negative_cash[:3])}' + 
                          (f' and {len(negative_cash)-3} more' if len(negative_cash) > 3 else ''),
                'severity': 'high'
            })
            alert_id += 1
        
        # Check for missing category groups
        revenue_accounts = Account.query.filter_by(
            church_id=church_id,
            account_type='REVENUE',
            is_active=True
        ).count()
        
        expense_accounts = Account.query.filter_by(
            church_id=church_id,
            account_type='EXPENSE',
            is_active=True
        ).count()
        
        if revenue_accounts == 0 or expense_accounts == 0:
            alerts.append({
                'id': alert_id,
                'type': 'info',
                'message': 'Chart of accounts may need seeding. Some account types are missing.',
                'severity': 'low'
            })
        
        return jsonify({'alerts': alerts}), 200
        
    except Exception as e:
        logger.error(f"Error getting alerts: {str(e)}")
        return jsonify({'error': 'Failed to get alerts'}), 500


