# ==================== TRIAL BALANCE ENDPOINTS ====================

@accounting_bp.route('/trial-balance', methods=['GET', 'OPTIONS'])
@token_required
def get_trial_balance():
    """Get trial balance"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        as_at_str = request.args.get('asAt')
        
        if as_at_str:
            as_at = datetime.fromisoformat(as_at_str)
        else:
            as_at = datetime.utcnow()
        
        # Get all active accounts
        accounts = Account.query.filter_by(
            church_id=church_id,
            is_active=True
        ).order_by(Account.account_type, Account.account_code).all()
        
        account_list = []
        total_debits = 0
        total_credits = 0
        
        print("\n" + "="*60)
        print("📊 TRIAL BALANCE CALCULATION")
        print("="*60)
        
        for acc in accounts:
            balance = float(acc.current_balance)
            
            # CORRECTED: Determine if balance should be debit or credit based on account type
            if acc.account_type == 'ASSET':
                # Assets normally have DEBIT balances
                debit = balance if balance > 0 else 0
                credit = abs(balance) if balance < 0 else 0
                print(f"{acc.account_code}: {acc.name} - ASSET - Balance: {balance:,.2f} → DEBIT: {debit:,.2f}, CREDIT: {credit:,.2f}")
                
            elif acc.account_type == 'EXPENSE':
                # Expenses normally have DEBIT balances
                debit = balance if balance > 0 else 0
                credit = abs(balance) if balance < 0 else 0
                print(f"{acc.account_code}: {acc.name} - EXPENSE - Balance: {balance:,.2f} → DEBIT: {debit:,.2f}, CREDIT: {credit:,.2f}")
                
            elif acc.account_type == 'LIABILITY':
                # Liabilities normally have CREDIT balances
                debit = abs(balance) if balance < 0 else 0
                credit = balance if balance > 0 else 0
                print(f"{acc.account_code}: {acc.name} - LIABILITY - Balance: {balance:,.2f} → DEBIT: {debit:,.2f}, CREDIT: {credit:,.2f}")
                
            elif acc.account_type == 'EQUITY':
                # Equity normally has CREDIT balances
                debit = abs(balance) if balance < 0 else 0
                credit = balance if balance > 0 else 0
                print(f"{acc.account_code}: {acc.name} - EQUITY - Balance: {balance:,.2f} → DEBIT: {debit:,.2f}, CREDIT: {credit:,.2f}")
                
            elif acc.account_type == 'REVENUE':
                # Revenue normally has CREDIT balances
                debit = abs(balance) if balance < 0 else 0
                credit = balance if balance > 0 else 0
                print(f"{acc.account_code}: {acc.name} - REVENUE - Balance: {balance:,.2f} → DEBIT: {debit:,.2f}, CREDIT: {credit:,.2f}")
                
            else:
                # Default fallback
                debit = balance if balance > 0 else 0
                credit = abs(balance) if balance < 0 else 0
                print(f"{acc.account_code}: {acc.name} - UNKNOWN - Balance: {balance:,.2f} → DEBIT: {debit:,.2f}, CREDIT: {credit:,.2f}")
            
            total_debits += debit
            total_credits += credit
            
            account_list.append({
                'id': acc.id,
                'code': acc.account_code,
                'name': acc.name,
                'type': acc.account_type,
                'category': acc.category,
                'debit': debit,
                'credit': credit,
                'balance': balance
            })
        
        print("-"*60)
        print(f"TOTAL DEBITS:  {total_debits:,.2f}")
        print(f"TOTAL CREDITS: {total_credits:,.2f}")
        print(f"DIFFERENCE:    {total_debits - total_credits:,.2f}")
        print(f"BALANCED: {abs(total_debits - total_credits) < 0.01}")
        print("="*60)
        
        return jsonify({
            'accounts': account_list,
            'totalDebits': total_debits,
            'totalCredits': total_credits,
            'difference': total_debits - total_credits,
            'isBalanced': abs(total_debits - total_credits) < 0.01,
            'asAt': as_at.isoformat()
        }), 200
        
    except Exception as e:
        logger.error(f"Error getting trial balance: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': 'Failed to get trial balance'}), 500

     
# ==================== FINANCIAL STATEMENTS ENDPOINTS ====================

@accounting_bp.route('/financial-statements', methods=['GET', 'OPTIONS'])
@token_required
def get_financial_statements():
    """Get financial statements using the service"""
    if request.method == 'OPTIONS':
        response = make_response()
        response.headers.add("Access-Control-Allow-Origin", "http://localhost:3000")
        response.headers.add("Access-Control-Allow-Headers", "Content-Type, Authorization")
        response.headers.add("Access-Control-Allow-Methods", "GET, OPTIONS")
        response.headers.add("Access-Control-Allow-Credentials", "true")
        return response, 200
    
    try:
        # Get church_id - g.current_user should be available due to @token_required
        church_id = None
        try:
            church_id = ensure_user_church(g.current_user)
            print(f"✅ Got church ID from user: {church_id}")
        except AttributeError as e:
            print(f"❌ AttributeError in ensure_user_church: {str(e)}")
            # g.current_user might not be set properly
            from app.models import User, Church
            
            # Try to get user from token manually
            from flask_jwt_extended import get_jwt_identity
            user_id = get_jwt_identity()
            if user_id:
                user = User.query.get(int(user_id))
                if user and user.church_id:
                    church_id = user.church_id
                    print(f"✅ Got church ID from manual user lookup: {church_id}")
            
            # If still no church_id, try default church
            if not church_id:
                default_church = Church.query.first()
                if default_church:
                    church_id = default_church.id
                    print(f"✅ Using default church ID: {church_id}")
        
        if not church_id:
            return jsonify({'error': 'Could not determine church ID'}), 400
        
        statement_type = request.args.get('type', 'income').lower()
        start_date_str = request.args.get('startDate')
        end_date_str = request.args.get('endDate')
        
        print(f"\n{'='*60}")
        print(f"📊 FINANCIAL STATEMENTS REQUEST")
        print(f"{'='*60}")
        print(f"Type: {statement_type}")
        print(f"Start Date: {start_date_str}")
        print(f"End Date: {end_date_str}")
        print(f"Church ID: {church_id}")
        
        # Import the service here to avoid circular imports
        try:
            from app.services.financial_statement_service import FinancialStatementService
            service = FinancialStatementService(church_id)
            print(f"✅ FinancialStatementService created successfully")
        except ImportError as e:
            print(f"❌ Import error: {str(e)}")
            return jsonify({'error': 'Financial statement service not available'}), 500
        except Exception as e:
            print(f"❌ Error creating service: {str(e)}")
            import traceback
            traceback.print_exc()
            return jsonify({'error': f'Service error: {str(e)}'}), 500
        
        # For balance sheet, only end date is required
        if statement_type in ['balance', 'balance-sheet']:
            if not end_date_str:
                return jsonify({'error': 'End date required for balance sheet'}), 400
            
            try:
                end_date = datetime.fromisoformat(end_date_str.replace('Z', '+00:00')).date()
                print(f"Parsed end date: {end_date}")
                
                data = service.get_balance_sheet(end_date)
                print(f"✅ Balance sheet data retrieved")
                
                # Ensure data has the expected structure
                if not data:
                    data = {'assets': {'items': [], 'total': 0}, 
                           'liabilities': {'items': [], 'total': 0}, 
                           'equity': {'items': [], 'total': 0}}
                
                return jsonify({
                    'title': 'Balance Sheet',
                    'type': 'balance',
                    'asOf': end_date_str,
                    'assets': data.get('assets', {'items': [], 'total': 0}),
                    'liabilities': data.get('liabilities', {'items': [], 'total': 0}),
                    'equity': data.get('equity', {'items': [], 'total': 0})
                }), 200
            except Exception as e:
                print(f"❌ Error getting balance sheet: {str(e)}")
                import traceback
                traceback.print_exc()
                return jsonify({'error': f'Balance sheet error: {str(e)}'}), 500
        
        # For income statement, both dates are required
        elif statement_type in ['income', 'income-statement']:
            if not start_date_str or not end_date_str:
                return jsonify({'error': 'Start date and end date required'}), 400
            
            try:
                start_date = datetime.fromisoformat(start_date_str.replace('Z', '+00:00')).date()
                end_date = datetime.fromisoformat(end_date_str.replace('Z', '+00:00')).date()
                print(f"Parsed dates: {start_date} to {end_date}")
                
                data = service.get_income_statement(start_date, end_date)
                print(f"✅ Income statement data retrieved")
                
                # Ensure data has the expected structure
                if not data:
                    data = {'revenue': {'items': [], 'total': 0, 'categories': {}}, 
                           'expenses': {'items': [], 'total': 0, 'categories': {}}, 
                           'net_income': 0}
                
                return jsonify({
                    'title': 'Income Statement',
                    'type': 'income',
                    'period': f"{start_date_str} to {end_date_str}",
                    'revenue': data.get('revenue', {'items': [], 'total': 0, 'categories': {}}),
                    'expenses': data.get('expenses', {'items': [], 'total': 0, 'categories': {}}),
                    'net_income': data.get('net_income', 0)
                }), 200
            except Exception as e:
                print(f"❌ Error getting income statement: {str(e)}")
                import traceback
                traceback.print_exc()
                return jsonify({'error': f'Income statement error: {str(e)}'}), 500
        
        # For receipt-payment account
        elif statement_type in ['receipt', 'receipt-payment']:
            if not start_date_str or not end_date_str:
                return jsonify({'error': 'Start date and end date required'}), 400
            
            try:
                start_date = datetime.fromisoformat(start_date_str.replace('Z', '+00:00')).date()
                end_date = datetime.fromisoformat(end_date_str.replace('Z', '+00:00')).date()
                print(f"Parsed dates: {start_date} to {end_date}")
                
                data = service.get_receipt_payment_account(start_date, end_date)
                print(f"✅ Receipt & Payment data retrieved")
                
                return jsonify({
                    'title': 'Receipt and Payment Account',
                    'type': 'receipt-payment',
                    'period': f"{start_date_str} to {end_date_str}",
                    'openingBalances': data.get('openingBalances', {'cashAccounts': [], 'bankAccounts': [], 'total': 0}),
                    'receipts': data.get('receipts', {'categories': {}, 'total': 0}),
                    'payments': data.get('payments', {'categories': {}, 'total': 0}),
                    'closingBalances': data.get('closingBalances', {'cashAccounts': [], 'bankAccounts': [], 'total': 0}),
                    'netCashFlow': data.get('netCashFlow', 0)
                }), 200
            except Exception as e:
                print(f"❌ Error getting receipt & payment: {str(e)}")
                import traceback
                traceback.print_exc()
                return jsonify({'error': f'Receipt & payment error: {str(e)}'}), 500
        
        # ===== ADD THIS CASH FLOW SECTION =====
        # For cash flow statement
        elif statement_type in ['cashflow', 'cash-flow', 'cash_flow']:
            if not start_date_str or not end_date_str:
                return jsonify({'error': 'Start date and end date required for cash flow statement'}), 400
            
            try:
                start_date = datetime.fromisoformat(start_date_str.replace('Z', '+00:00')).date()
                end_date = datetime.fromisoformat(end_date_str.replace('Z', '+00:00')).date()
                print(f"Parsed dates: {start_date} to {end_date}")
                
                # Try to get cash flow data from service
                try:
                    data = service.get_cash_flow_statement(start_date, end_date)
                    print(f"✅ Cash flow data retrieved")
                except Exception as e:
                    print(f"⚠️ Error getting cash flow data: {str(e)}")
                    # Return a default structure if the method doesn't exist or fails
                    data = {
                        'operating': {'items': [], 'net': 0},
                        'investing': {'items': [], 'net': 0},
                        'financing': {'items': [], 'net': 0},
                        'netIncrease': 0,
                        'beginningCash': 0,
                        'endingCash': 0
                    }
                
                return jsonify({
                    'title': 'Cash Flow Statement',
                    'type': 'cashflow',
                    'period': f"{start_date_str} to {end_date_str}",
                    'operating': data.get('operating', {'items': [], 'net': 0}),
                    'investing': data.get('investing', {'items': [], 'net': 0}),
                    'financing': data.get('financing', {'items': [], 'net': 0}),
                    'netIncrease': data.get('netIncrease', 0),
                    'beginningCash': data.get('beginningCash', 0),
                    'endingCash': data.get('endingCash', 0)
                }), 200
            except Exception as e:
                print(f"❌ Error getting cash flow: {str(e)}")
                import traceback
                traceback.print_exc()
                return jsonify({'error': f'Cash flow error: {str(e)}'}), 500
        
        else:
            return jsonify({'error': f'Invalid statement type: {statement_type}'}), 400
            
    except Exception as e:
        print(f"❌ Unhandled error in financial statements: {str(e)}")
        import traceback
        traceback.print_exc()
        return jsonify({'error': f'Server error: {str(e)}'}), 500
                    
# ==================== EXPORT ENDPOINTS ====================

@accounting_bp.route('/financial-statements/export', methods=['GET', 'OPTIONS'])
@token_required
def export_financial_statement():
    """Export financial statement as CSV or PDF"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        statement_type = request.args.get('type', 'income').lower()
        start_date = request.args.get('startDate')
        end_date = request.args.get('endDate')
        format_type = request.args.get('format', 'csv').lower()
        
        if not start_date or not end_date:
            return jsonify({'error': 'Start date and end date required'}), 400
        
        start = datetime.fromisoformat(start_date.replace('Z', '+00:00'))
        end = datetime.fromisoformat(end_date.replace('Z', '+00:00'))
        end = end.replace(hour=23, minute=59, second=59)
        
        service = FinancialStatementService(church_id)
        
        # Get the statement data first
        if statement_type == 'receipt-payment':
            statement_data = service.get_receipt_payment_account(start.date(), end.date())
        elif statement_type == 'income':
            statement_data = service.get_income_statement(start.date(), end.date())
        elif statement_type == 'balance':
            statement_data = service.get_balance_sheet(end.date())
        elif statement_type == 'cashflow':
            statement_data = service.get_cash_flow_statement(start.date(), end.date())
        else:
            return jsonify({'error': 'Invalid statement type'}), 400
        
        if format_type == 'csv':
            return export_as_csv(statement_data, statement_type, start_date, end_date)
        elif format_type == 'pdf':
            return export_as_pdf(statement_data, statement_type, start_date, end_date)
        else:
            return jsonify({'error': 'Unsupported format'}), 400
            
    except Exception as e:
        logger.error(f"Error exporting statement: {str(e)}")
        logger.error(traceback.format_exc())
        return jsonify({'error': 'Failed to export statement'}), 500





@accounting_bp.route('/financial-statements-with-budget', methods=['GET', 'OPTIONS'])
@token_required
def get_financial_statements_with_budget():
    """Get financial statements with budget variance analysis"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        start_date_str = request.args.get('startDate')
        end_date_str = request.args.get('endDate')
        
        if not start_date_str or not end_date_str:
            return jsonify({'error': 'startDate and endDate are required'}), 400
        
        start = datetime.fromisoformat(start_date_str.replace('Z', '+00:00')).date()
        end = datetime.fromisoformat(end_date_str.replace('Z', '+00:00')).date()
        year = start.year
        
        # Get income statement data
        service = FinancialStatementService(church_id)
        income_data = service.get_income_statement(start, end)
        
        # Get budget data
        from app.models import Budget
        
        revenue_budgets = Budget.query.filter_by(
            church_id=church_id,
            fiscal_year=year,
            budget_type='REVENUE',
            status='APPROVED'
        ).all()
        
        expense_budgets = Budget.query.filter_by(
            church_id=church_id,
            fiscal_year=year,
            budget_type='EXPENSE',
            status='APPROVED'
        ).all()
        
        # Calculate total budgets
        total_revenue_budget = sum(float(b.amount) for b in revenue_budgets)
        total_expense_budget = sum(float(b.amount) for b in expense_budgets)
        
        # Get actual totals
        total_revenue_actual = income_data['revenue']['total']
        total_expense_actual = income_data['expenses']['total']
        
        # Calculate variances
        revenue_variance = total_revenue_actual - total_revenue_budget
        expense_variance = total_expense_actual - total_expense_budget
        net_variance = (total_revenue_actual - total_expense_actual) - (total_revenue_budget - total_expense_budget)
        
        return jsonify({
            'income_statement': income_data,
            'budget_comparison': {
                'revenue': {
                    'budget': round(total_revenue_budget, 2),
                    'actual': round(total_revenue_actual, 2),
                    'variance': round(revenue_variance, 2),
                    'variance_percentage': round((revenue_variance / total_revenue_budget * 100) if total_revenue_budget > 0 else 0, 2),
                    'favorable': revenue_variance > 0
                },
                'expenses': {
                    'budget': round(total_expense_budget, 2),
                    'actual': round(total_expense_actual, 2),
                    'variance': round(expense_variance, 2),
                    'variance_percentage': round((expense_variance / total_expense_budget * 100) if total_expense_budget > 0 else 0, 2),
                    'favorable': expense_variance < 0
                },
                'net': {
                    'budget': round(total_revenue_budget - total_expense_budget, 2),
                    'actual': round(total_revenue_actual - total_expense_actual, 2),
                    'variance': round(net_variance, 2),
                    'favorable': net_variance > 0
                }
            },
            'period': {
                'start': start.isoformat(),
                'end': end.isoformat()
            }
        }), 200
        
    except Exception as e:
        logger.error(f"Error getting financial statements with budget: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': str(e)}), 500 

