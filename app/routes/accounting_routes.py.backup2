# ==================== CHART OF ACCOUNTS ENDPOINTS ====================

@accounting_bp.route('/chart-of-accounts', methods=['GET', 'OPTIONS'])
@token_required
def get_chart_of_accounts():
    """Get the full chart of accounts structure"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        
        # Get all accounts for this church
        accounts = Account.query.filter_by(
            church_id=church_id,
            is_active=True
        ).order_by(Account.account_code).all()
        
        # Organize by type with proper categories
        result = {
            'REVENUE': [],
            'EXPENSE': [],
            'ASSET': [],
            'LIABILITY': [],
            'EQUITY': []
        }
        
        for account in accounts:
            account_dict = account.to_dict(include_children=False)
            
            # Add category group information
            for group_name, codes in CATEGORY_GROUPS.get('income', {}).items():
                if account.account_code in codes:
                    account_dict['category_group'] = group_name
                    break
            
            for group_name, codes in CATEGORY_GROUPS.get('expenses', {}).items():
                if account.account_code in codes:
                    account_dict['category_group'] = group_name
                    break
            
            result[account.account_type].append(account_dict)
        
        return jsonify({
            'chart_of_accounts': result,
            'category_groups': CATEGORY_GROUPS
        }), 200
        
    except Exception as e:
        logger.error(f"Error getting chart of accounts: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': str(e)}), 500


@accounting_bp.route('/chart-of-accounts/seed', methods=['POST', 'OPTIONS'])
@token_required
def seed_chart_of_accounts():
    """Seed the default chart of accounts"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        current_user = get_current_user()
        
        from app.models.chart_of_accounts import CHART_OF_ACCOUNTS
        
        created = []
        skipped = []
        
        for account_type, accounts in CHART_OF_ACCOUNTS.items():
            for account_data in accounts:
                # Check if account already exists
                existing = Account.query.filter_by(
                    church_id=church_id,
                    account_code=account_data['code']
                ).first()
                
                if existing:
                    skipped.append(account_data['code'])
                    continue
                
                account = Account(
                    church_id=church_id,
                    account_code=account_data['code'],
                    name=account_data['name'],
                    display_name=account_data['name'],
                    account_type=account_type,
                    category=account_data.get('category'),
                    sub_category=account_data.get('sub_category'),
                    normal_balance=account_data.get('normal_balance', 'debit'),
                    is_contra=account_data.get('is_contra', False),
                    level=1 if len(account_data['code']) == 4 else 2,
                    created_by=current_user.id if current_user else None
                )
                db.session.add(account)
                created.append(account_data['code'])
        
        db.session.commit()
        
        return jsonify({
            'message': f'Created {len(created)} accounts, {len(skipped)} already existed',
            'created': created,
            'skipped': skipped
        }), 201
        
    except Exception as e:
        db.session.rollback()
        logger.error(f"Error seeding chart of accounts: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': str(e)}), 500


@accounting_bp.route('/accounts/<int:account_id>/balance', methods=['GET', 'OPTIONS'])
@token_required
def get_account_balance(account_id):
    """Get detailed balance for a specific account"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        
        account = Account.query.filter_by(
            id=account_id,
            church_id=church_id
        ).first()
        
        if not account:
            return jsonify({'error': 'Account not found'}), 404
        
        # Get transactions for this account
        from app.models import JournalLine, JournalEntry
        
        transactions = db.session.query(
            JournalLine,
            JournalEntry
        ).join(
            JournalEntry,
            JournalLine.journal_entry_id == JournalEntry.id
        ).filter(
            JournalLine.account_id == account_id,
            JournalEntry.church_id == church_id,
            JournalEntry.status == 'POSTED'
        ).order_by(
            JournalEntry.entry_date.desc()
        ).limit(100).all()
        
        transaction_list = []
        running_balance = float(account.opening_balance)
        
        # Sort by date ascending for running balance calculation
        transactions.reverse()
        
        for line, entry in transactions:
            if line.debit > 0:
                running_balance += float(line.debit)
            else:
                running_balance -= float(line.credit)
            
            transaction_list.append({
                'date': entry.entry_date.isoformat(),
                'description': entry.description,
                'debit': float(line.debit),
                'credit': float(line.credit),
                'balance': running_balance,
                'reference': entry.entry_number
            })
        
        # Sort back to descending for display
        transaction_list.reverse()
        
        return jsonify({
            'account': {
                'id': account.id,
                'code': account.account_code,
                'name': account.name,
                'type': account.account_type,  # ← CORRECT FIELD NAME
                'category': account.category
            },
            'transactions': transaction_list,
            'current_balance': float(account.current_balance)
        }), 200
        
    except Exception as e:
        print(f"❌ Error getting account balance: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': str(e)}), 500

@accounting_bp.route('/accounts/by-category', methods=['GET', 'OPTIONS'])
@token_required
def get_accounts_by_category():
    """Get accounts grouped by category for dropdowns"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        
        accounts = Account.query.filter_by(
            church_id=church_id,
            is_active=True
        ).order_by(Account.account_type, Account.category, Account.account_code).all()
        
        result = {}
        for account in accounts:
            acc_type = account.account_type
            if acc_type not in result:
                result[acc_type] = {}
            
            category = account.category or 'Other'
            if category not in result[acc_type]:
                result[acc_type][category] = []
            
            result[acc_type][category].append({
                'id': account.id,
                'code': account.account_code,
                'name': account.name,
                'balance': float(account.current_balance)
            })
        
        return jsonify(result), 200
        
    except Exception as e:
        logger.error(f"Error getting accounts by category: {str(e)}")
        return jsonify({'error': str(e)}), 500


# ==================== DASHBOARD ENDPOINTS ====================

@accounting_bp.route('/dashboard-stats', methods=['GET', 'OPTIONS'])
@token_required
def get_dashboard_stats():
    """Get accounting dashboard statistics including journal entries"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        
        # Use service for consistent calculations
        service = FinancialStatementService(church_id)
        
        # Get income statement for current month
        today = datetime.utcnow()
        month_start = today.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
        
        income_data = service.get_income_statement(month_start.date(), today.date())
        
        # Get account counts by type
        account_counts = db.session.query(
            Account.account_type,
            func.count(Account.id).label('count')
        ).filter(
            Account.church_id == church_id,
            Account.is_active == True
        ).group_by(Account.account_type).all()
        
        counts_dict = {acc_type: count for acc_type, count in account_counts}
        
        # Get journal entry counts by status
        from app.models import JournalEntry
        entry_counts = db.session.query(
            JournalEntry.status,
            func.count(JournalEntry.id).label('count')
        ).filter(
            JournalEntry.church_id == church_id
        ).group_by(JournalEntry.status).all()
        
        entry_dict = {status: count for status, count in entry_counts}
        
        # Get recent activity
        recent_count = JournalEntry.query.filter(
            JournalEntry.church_id == church_id,
            JournalEntry.entry_date >= month_start
        ).count()
        
        return jsonify({
            'totalIncome': income_data['revenue']['total'],
            'totalExpenses': income_data['expenses']['total'],
            'netIncome': income_data['net_income'],
            'accountCounts': counts_dict,
            'journalEntryStats': {
                'posted': entry_dict.get('POSTED', 0),
                'draft': entry_dict.get('DRAFT', 0),
                'void': entry_dict.get('VOID', 0)
            },
            'recentEntries': recent_count,
            'incomeByCategory': [
                {'category': cat, 'total': data['total']}
                for cat, data in income_data['revenue']['categories'].items()
            ],
            'expenseByCategory': [
                {'category': cat, 'total': data['total']}
                for cat, data in income_data['expenses']['categories'].items()
            ]
        }), 200
        
    except Exception as e:
        logger.error(f"Error getting dashboard stats: {str(e)}")
        logger.error(traceback.format_exc())
        return jsonify({'error': 'Failed to get dashboard stats'}), 500


@accounting_bp.route('/recent-entries', methods=['GET', 'OPTIONS'])
@token_required
def get_recent_entries():
    """Get recent journal entries including both transactions and journal entries"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        limit = request.args.get('limit', 10, type=int)
        
        from app.models import JournalEntry, JournalLine
        
        # Get recent journal entries with proper account information
        journal_entries = JournalEntry.query.filter_by(
            church_id=church_id
        ).order_by(
            JournalEntry.entry_date.desc()
        ).limit(limit).all()
        
        entries = []
        for je in journal_entries:
            # Get account names for the lines
            lines_info = []
            for line in je.lines:
                account = Account.query.get(line.account_id)
                lines_info.append({
                    'account_name': account.name if account else 'Unknown',
                    'debit': float(line.debit),
                    'credit': float(line.credit)
                })
            
            entries.append({
                'id': je.id,
                'type': 'journal',
                'number': je.entry_number,
                'date': je.entry_date.isoformat(),
                'description': je.description or 'Journal Entry',
                'lines': lines_info,
                'status': je.status.lower()
            })
        
        return jsonify({'entries': entries}), 200
        
    except Exception as e:
        logger.error(f"Error getting recent entries: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': 'Failed to get recent entries'}), 500


@accounting_bp.route('/monthly-trend', methods=['GET', 'OPTIONS'])
@token_required
def get_monthly_trend():
    """Get monthly income/expense trend"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        
        # Get last 12 months of data
        end_date = datetime.utcnow()
        start_date = end_date - timedelta(days=365)
        
        from app.models import JournalEntry, JournalLine
        
        # Query monthly aggregates from journal entries
        results = db.session.query(
            func.strftime('%Y-%m', JournalEntry.entry_date).label('month'),
            func.sum(JournalLine.credit).filter(Account.account_type == 'REVENUE').label('income'),
            func.sum(JournalLine.debit).filter(Account.account_type == 'EXPENSE').label('expenses')
        ).join(
            JournalLine, JournalLine.journal_entry_id == JournalEntry.id
        ).join(
            Account, Account.id == JournalLine.account_id
        ).filter(
            JournalEntry.church_id == church_id,
            JournalEntry.entry_date >= start_date,
            JournalEntry.entry_date <= end_date,
            JournalEntry.status == 'POSTED'
        ).group_by('month').order_by('month').all()
        
        months = []
        for r in results:
            months.append({
                'month': r.month,
                'income': float(r.income or 0),
                'expenses': float(r.expenses or 0)
            })
        
        return jsonify(months), 200
        
    except Exception as e:
        logger.error(f"Error getting monthly trend: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': 'Failed to get monthly trend'}), 500


