@accounting_bp.route('/bank-accounts', methods=['GET', 'OPTIONS'])
@token_required
def get_bank_accounts():
    """Get bank accounts for reconciliation"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        
        # Get accounts that are likely bank accounts (code starts with 1020-1029)
        bank_accounts = Account.query.filter(
            Account.church_id == church_id,
            Account.account_type == 'ASSET',  # ← CORRECT FIELD NAME
            Account.account_code.like('102%'),
            Account.is_active == True
        ).all()
        
        account_list = []
        for acc in bank_accounts:
            account_list.append({
                'id': acc.id,
                'name': acc.name,
                'accountNumber': acc.account_code,
                'bank': acc.category or 'Bank Account',
                'balance': float(acc.current_balance)
            })
        
        return jsonify({'accounts': account_list}), 200
        
    except Exception as e:
        print(f"❌ Error getting bank accounts: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': 'Failed to get bank accounts'}), 500  

# ==================== RECONCILIATION ENDPOINTS ====================
@accounting_bp.route('/reconciliation', methods=['GET', 'OPTIONS'])
@token_required
def get_reconciliation_data():
    """Get reconciliation data for an account"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        print("\n" + "="*60)
        print("📋 RECONCILIATION DATA REQUEST")
        print("="*60)
        
        account_id = request.args.get('accountId', type=int)
        as_of = request.args.get('asOf')
        
        print(f"Account ID: {account_id}")
        print(f"As of: {as_of}")
        
        if not account_id:
            print("❌ No account ID provided")
            return jsonify({'error': 'Account ID is required'}), 400
        
        # Parse date
        if as_of:
            try:
                as_of_date = datetime.fromisoformat(as_of.replace('Z', '+00:00'))
                print(f"Parsed date: {as_of_date}")
            except Exception as e:
                print(f"Date parsing error: {e}")
                as_of_date = datetime.utcnow()
        else:
            as_of_date = datetime.utcnow()
        
        # Get account
        print(f"Fetching account with ID: {account_id}")
        account = Account.query.get(account_id)
        
        if not account:
            print(f"❌ Account {account_id} not found")
            return jsonify({'error': 'Account not found'}), 404
        
        print(f"✅ Found account: {account.account_code} - {account.name}")
        print(f"   Account type: {account.account_type}")
        print(f"   Current balance: {account.current_balance}")
        
        # Get transactions for this account using JournalLine
        from app.models import JournalLine, JournalEntry
        
        print(f"Fetching transactions for account ID: {account_id}")
        
        # Get all posted journal entries for this account
        transactions = db.session.query(
            JournalLine, JournalEntry
        ).join(
            JournalEntry, JournalLine.journal_entry_id == JournalEntry.id
        ).filter(
            JournalLine.account_id == account_id,
            JournalEntry.church_id == g.current_user.church_id,
            JournalEntry.status == 'POSTED'
        ).order_by(JournalEntry.entry_date.desc()).all()
        
        print(f"Found {len(transactions)} transactions")
        
        # Split into reconciled and unreconciled
        reconciled = []
        unreconciled = []
        
        for i, (line, entry) in enumerate(transactions):
            print(f"  Transaction {i+1}:")
            print(f"    Entry: {entry.entry_number} - {entry.description}")
            print(f"    Line: debit={line.debit}, credit={line.credit}")
            
            transaction_data = {
                'id': line.id,
                'date': entry.entry_date.isoformat() if entry.entry_date else None,
                'description': entry.description,
                'reference': entry.entry_number,
                'amount': float(line.debit or line.credit),
                'type': 'debit' if line.debit > 0 else 'credit',
                'status': entry.status,
                'reconciled': False,
                'reconciliation_date': None
            }
            unreconciled.append(transaction_data)
        
        # Prepare response
        response_data = {
            'account': {
                'id': account.id,
                'name': account.name,
                'type': account.account_type,  # Using correct field name
                'code': account.account_code
            },
            'statement_balance': float(account.current_balance),
            'book_balance': float(account.current_balance),
            'reconciled_items': reconciled,
            'unreconciled_items': unreconciled,
            'as_of': as_of_date.isoformat(),
            'summary': {
                'total_reconciled': len(reconciled),
                'total_unreconciled': len(unreconciled),
                'reconciled_amount': sum(float(t['amount']) for t in reconciled),
                'unreconciled_amount': sum(float(t['amount']) for t in unreconciled)
            }
        }
        
        print("\n✅ Sending response:")
        print(f"   Account type: {response_data['account']['type']}")
        print(f"   Total transactions: {len(unreconciled)}")
        print("="*60)
        
        return jsonify(response_data), 200
        
    except Exception as e:
        print(f"\n❌ ERROR in reconciliation: {str(e)}")
        print(traceback.format_exc())
        return jsonify({'error': str(e)}), 500

@accounting_bp.route('/reconciliation/<int:transaction_id>/reconcile', methods=['POST', 'OPTIONS'])
@token_required
def reconcile_transaction(transaction_id):
    """Mark a transaction as reconciled"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        transaction = Transaction.query.get(transaction_id)
        if not transaction:
            return jsonify({'error': 'Transaction not found'}), 404
        
        transaction.reconciliation_date = datetime.utcnow()
        db.session.commit()
        
        # Log audit
        audit_log = AuditLog(
            user_id=g.current_user.id,
            action='RECONCILE_TRANSACTION',
            resource='transaction',
            resource_id=transaction_id,
            ip_address=request.remote_addr,
            user_agent=request.user_agent.string
        )
        db.session.add(audit_log)
        db.session.commit()
        
        return jsonify({'message': 'Transaction reconciled successfully'}), 200
        
    except Exception as e:
        db.session.rollback()
        logger.error(f"Error reconciling transaction: {str(e)}")
        return jsonify({'error': 'Failed to reconcile transaction'}), 500


@accounting_bp.route('/reconciliation/<int:transaction_id>/unreconcile', methods=['POST', 'OPTIONS'])
@token_required
def unreconcile_transaction(transaction_id):
    """Unreconcile a transaction"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        transaction = Transaction.query.get(transaction_id)
        if not transaction:
            return jsonify({'error': 'Transaction not found'}), 404
        
        transaction.reconciliation_date = None
        db.session.commit()
        
        # Log audit
        audit_log = AuditLog(
            user_id=g.current_user.id,
            action='UNRECONCILE_TRANSACTION',
            resource='transaction',
            resource_id=transaction_id,
            ip_address=request.remote_addr,
            user_agent=request.user_agent.string
        )
        db.session.add(audit_log)
        db.session.commit()
        
        return jsonify({'message': 'Transaction unreconciled successfully'}), 200
        
    except Exception as e:
        db.session.rollback()
        logger.error(f"Error unreconciling transaction: {str(e)}")
        return jsonify({'error': 'Failed to unreconcile transaction'}), 500


# ==================== TAX REPORTS ENDPOINTS ====================

@accounting_bp.route('/tax-reports', methods=['GET', 'OPTIONS'])
@token_required
def get_tax_reports():
    """Get tax reports"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        year = request.args.get('year', datetime.utcnow().year, type=int)
        report_type = request.args.get('type', 'summary')
        
        start_date = datetime(year, 1, 1)
        end_date = datetime(year, 12, 31, 23, 59, 59)
        
        if report_type == 'summary':
            # Get total income for the year
            total_income = db.session.query(func.sum(Transaction.amount)).filter(
                Transaction.church_id == church_id,
                Transaction.transaction_type == 'INCOME',
                Transaction.transaction_date >= start_date,
                Transaction.transaction_date <= end_date,
                Transaction.status == 'POSTED'
            ).scalar() or 0
            
            # Get tax-exempt income (assuming certain categories are exempt)
            tax_exempt = db.session.query(func.sum(Transaction.amount)).filter(
                Transaction.church_id == church_id,
                Transaction.transaction_type == 'INCOME',
                Transaction.category.in_(['DONATION', 'GIFT']),
                Transaction.transaction_date >= start_date,
                Transaction.transaction_date <= end_date,
                Transaction.status == 'POSTED'
            ).scalar() or 0
            
            taxable_income = total_income - tax_exempt
            
            # Get taxes paid (assuming expense account for taxes)
            taxes_paid = db.session.query(func.sum(Transaction.amount)).filter(
                Transaction.church_id == church_id,
                Transaction.transaction_type == 'EXPENSE',
                Transaction.category == 'TAX',
                Transaction.transaction_date >= start_date,
                Transaction.transaction_date <= end_date,
                Transaction.status == 'POSTED'
            ).scalar() or 0
            
            # Quarterly breakdown
            quarters = []
            for q in range(1, 5):
                q_start = datetime(year, (q-1)*3 + 1, 1)
                if q < 4:
                    q_end = datetime(year, q*3, 1).replace(day=1) - timedelta(days=1)
                else:
                    q_end = datetime(year, 12, 31)
                
                q_income = db.session.query(func.sum(Transaction.amount)).filter(
                    Transaction.church_id == church_id,
                    Transaction.transaction_type == 'INCOME',
                    Transaction.transaction_date >= q_start,
                    Transaction.transaction_date <= q_end,
                    Transaction.status == 'POSTED'
                ).scalar() or 0
                
                q_tax_paid = db.session.query(func.sum(Transaction.amount)).filter(
                    Transaction.church_id == church_id,
                    Transaction.transaction_type == 'EXPENSE',
                    Transaction.category == 'TAX',
                    Transaction.transaction_date >= q_start,
                    Transaction.transaction_date <= q_end,
                    Transaction.status == 'POSTED'
                ).scalar() or 0
                
                quarters.append({
                    'quarter': f'Q{q}',
                    'income': float(q_income),
                    'estimatedTax': float(q_income * 0.05),
                    'paid': float(q_tax_paid)
                })
            
            return jsonify({
                'summary': {
                    'totalIncome': float(total_income),
                    'taxableIncome': float(taxable_income),
                    'taxExemptIncome': float(tax_exempt),
                    'estimatedTax': float(taxable_income * 0.05),
                    'paidTaxes': float(taxes_paid),
                    'taxDue': float(max(0, (taxable_income * 0.05) - taxes_paid)),
                    'quarters': quarters
                }
            }), 200
            
        elif report_type == 'withholding':
            # Get salary/wage expenses
            salaries = db.session.query(
                Transaction.description,
                func.sum(Transaction.amount).label('total')
            ).filter(
                Transaction.church_id == church_id,
                Transaction.transaction_type == 'EXPENSE',
                Transaction.category.in_(['SALARY', 'WAGE']),
                Transaction.transaction_date >= start_date,
                Transaction.transaction_date <= end_date,
                Transaction.status == 'POSTED'
            ).group_by(Transaction.description).all()
            
            withholdings = []
            for sal in salaries:
                federal = sal.total * 0.15
                state = sal.total * 0.05
                fica = sal.total * 0.0765
                
                withholdings.append({
                    'employee': sal.description,
                    'position': 'Employee',
                    'wages': float(sal.total),
                    'federalWithheld': float(federal),
                    'stateWithheld': float(state),
                    'ficaWithheld': float(fica)
                })
            
            return jsonify({'withholdings': withholdings}), 200
            
        elif report_type == 'donor':
            # Get donor contributions
            donors = db.session.query(
                Member,
                func.sum(Transaction.amount).label('total')
            ).join(
                Transaction, Transaction.member_id == Member.id
            ).filter(
                Transaction.church_id == church_id,
                Transaction.transaction_type == 'INCOME',
                Transaction.category.in_(['TITHE', 'OFFERING', 'DONATION']),
                Transaction.transaction_date >= start_date,
                Transaction.transaction_date <= end_date,
                Transaction.status == 'POSTED'
            ).group_by(Member.id).all()
            
            donor_list = []
            for donor, total in donors:
                donor_list.append({
                    'id': donor.id,
                    'name': donor.full_name() if hasattr(donor, 'full_name') else f"{donor.first_name} {donor.last_name}",
                    'totalGifts': float(total),
                    'cash': float(total),
                    'nonCash': 0,
                    'statements': 1
                })
            
            return jsonify({'donors': donor_list}), 200
            
        elif report_type == '1099':
            # Get 1099 contractors
            contractors = db.session.query(
                Transaction.description,
                func.sum(Transaction.amount).label('total')
            ).filter(
                Transaction.church_id == church_id,
                Transaction.transaction_type == 'EXPENSE',
                Transaction.category == 'CONTRACTOR',
                Transaction.transaction_date >= start_date,
                Transaction.transaction_date <= end_date,
                Transaction.status == 'POSTED'
            ).group_by(Transaction.description).having(func.sum(Transaction.amount) >= 600).all()
            
            contractor_list = []
            for contractor, total in contractors:
                contractor_list.append({
                    'name': contractor,
                    'ein': 'XXX-XX-XXXX',
                    'amount': float(total),
                    'reportable': total >= 600
                })
            
            return jsonify({'contractors': contractor_list}), 200
        
        return jsonify({'error': 'Invalid report type'}), 400
        
    except Exception as e:
        logger.error(f"Error getting tax reports: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': 'Failed to get tax reports'}), 500


@accounting_bp.route('/tax-reports/export', methods=['GET', 'OPTIONS'])
@token_required
def export_tax_report():
    """Export tax report as CSV"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        year = request.args.get('year', datetime.utcnow().year, type=int)
        report_type = request.args.get('type', 'summary')
        
        start_date = datetime(year, 1, 1)
        end_date = datetime(year, 12, 31, 23, 59, 59)
        
        output = io.StringIO()
        writer = csv.writer(output)
        
        if report_type == 'donor':
            writer.writerow(['Donor Name', 'Total Gifts', 'Cash', 'Non-Cash', 'Statements'])
            
            donors = db.session.query(
                Member,
                func.sum(Transaction.amount).label('total')
            ).join(
                Transaction, Transaction.member_id == Member.id
            ).filter(
                Transaction.church_id == church_id,
                Transaction.transaction_type == 'INCOME',
                Transaction.category.in_(['TITHE', 'OFFERING', 'DONATION']),
                Transaction.transaction_date >= start_date,
                Transaction.transaction_date <= end_date,
                Transaction.status == 'POSTED'
            ).group_by(Member.id).all()
            
            for donor, total in donors:
                donor_name = donor.full_name() if hasattr(donor, 'full_name') else f"{donor.first_name} {donor.last_name}"
                writer.writerow([
                    donor_name,
                    f"${total:.2f}",
                    f"${total:.2f}",
                    '$0.00',
                    '1'
                ])
            
        elif report_type == '1099':
            writer.writerow(['Contractor Name', 'EIN', 'Amount', 'Reportable'])
            
            contractors = db.session.query(
                Transaction.description,
                func.sum(Transaction.amount).label('total')
            ).filter(
                Transaction.church_id == church_id,
                Transaction.transaction_type == 'EXPENSE',
                Transaction.category == 'CONTRACTOR',
                Transaction.transaction_date >= start_date,
                Transaction.transaction_date <= end_date,
                Transaction.status == 'POSTED'
            ).group_by(Transaction.description).all()
            
            for contractor, total in contractors:
                writer.writerow([
                    contractor,
                    'XXX-XX-XXXX',
                    f"${total:.2f}",
                    'Yes' if total >= 600 else 'No'
                ])
        
        output.seek(0)
        response = make_response(output.getvalue())
        response.headers['Content-Type'] = 'text/csv'
        response.headers['Content-Disposition'] = f'attachment; filename={report_type}_report_{year}.csv'
        
        return response
        
    except Exception as e:
        logger.error(f"Error exporting tax report: {str(e)}")
        traceback.print_exc()
        return jsonify({'error': 'Failed to export tax report'}), 500


@accounting_bp.route('/ledger', methods=['GET', 'OPTIONS'])   
@token_required
def get_general_ledger():
    """Get general ledger entries for an account"""
    if request.method == 'OPTIONS':
        return '', 200
    
    try:
        church_id = ensure_user_church(g.current_user)
        account_id = request.args.get('accountId', type=int)
        start_date_str = request.args.get('startDate')
        end_date_str = request.args.get('endDate')
        
        if not account_id:
            return jsonify({'error': 'Account ID is required'}), 400
        
        # Get the account
        account = Account.query.filter_by(
            id=account_id,
            church_id=church_id
        ).first()
        
        if not account:
            return jsonify({'error': 'Account not found'}), 404
        
        # Parse dates
        start_date = None
        end_date = None
        
        if start_date_str:
            try:
                start_date = datetime.fromisoformat(start_date_str.replace('Z', '+00:00'))
            except (ValueError, TypeError):
                start_date = datetime.utcnow().replace(day=1, hour=0, minute=0, second=0, microsecond=0)
        
        if end_date_str:
            try:
                end_date = datetime.fromisoformat(end_date_str.replace('Z', '+00:00'))
                end_date = end_date.replace(hour=23, minute=59, second=59)
            except (ValueError, TypeError):
                end_date = datetime.utcnow()
        
        # Build query for journal entries
        from app.models import JournalEntry, JournalLine
        
        query = db.session.query(
            JournalLine, JournalEntry
        ).join(
            JournalEntry, JournalLine.journal_entry_id == JournalEntry.id
        ).filter(
            JournalLine.account_id == account_id,
            JournalEntry.church_id == church_id,
            JournalEntry.status == 'POSTED'
        )
        
        if start_date:
            query = query.filter(JournalEntry.entry_date >= start_date)
        
        if end_date:
            query = query.filter(JournalEntry.entry_date <= end_date)
        
        results = query.order_by(JournalEntry.entry_date).all()
        
        # Calculate running balance - FIX: Handle None values
        opening_balance = float(account.opening_balance) if account.opening_balance is not None else 0.0
        running_balance = opening_balance
        
        entries = []
        
        # Add opening balance entry
        if results or opening_balance != 0:
            entries.append({
                'id': None,
                'date': (start_date or datetime.utcnow()).isoformat() if start_date else account.created_at.isoformat(),
                'description': 'Opening Balance',
                'reference': 'OPENING',
                'debit': 0,
                'credit': 0,
                'balance': running_balance,
                'isOpening': True
            })
        
        for line, entry in results:
            if line.debit > 0:
                running_balance += float(line.debit)
            else:
                running_balance -= float(line.credit)
            
            entries.append({
                'id': line.id,
                'date': entry.entry_date.isoformat(),
                'description': entry.description,
                'reference': entry.entry_number,
                'debit': float(line.debit),
                'credit': float(line.credit),
                'balance': running_balance
            })
        
        # Calculate summary
        total_debit = sum(e['debit'] for e in entries if not e.get('isOpening'))
        total_credit = sum(e['credit'] for e in entries if not e.get('isOpening'))
        
        return jsonify({
            'account': {
                'id': account.id,
                'code': account.account_code,
                'name': account.name,
                'type': account.account_type
            },
            'entries': entries,
            'summary': {
                'openingBalance': opening_balance,
                'totalDebit': float(total_debit),
                'totalCredit': float(total_credit),
                'closingBalance': float(running_balance)
            }
        }), 200
        
    except Exception as e:
        logger.error(f"Error getting ledger: {str(e)}")
        logger.error(traceback.format_exc())
        return jsonify({'error': 'Failed to get ledger entries'}), 500 

